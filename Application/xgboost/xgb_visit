def estimate_decision_rules(tau_Y_hat, tau_S_hat, lambda_val):
    def select_top_lambda(tau_hat, lambda_val):
        n = len(tau_hat)
        target_count = int(np.round(n * lambda_val))

        # Sort by value in descending order first, get sorted indices
        sorted_indices = np.argsort(-tau_hat)
        sorted_values = tau_hat[sorted_indices]

        # Initialize selection array
        selected = np.zeros(n, dtype=int)

        if target_count == 0:
            return selected

        # Find the value of the target_count-th element (quantile)
        threshold = sorted_values[target_count - 1]

        # First select all elements strictly greater than threshold
        strict_greater = tau_hat > threshold
        selected[strict_greater] = 1

        # Calculate how many more elements equal to threshold need to be selected
        remaining_spots = target_count - np.sum(strict_greater)

        if remaining_spots > 0:
            # Find all positions equal to threshold and greater than 0
            equal_threshold_and_positive = (tau_hat == threshold) & (tau_hat > 0)
            equal_indices = np.where(equal_threshold_and_positive)[0]

            if len(equal_indices) > 0:
                # Randomly select remaining_spots positions
                if remaining_spots >= len(equal_indices):
                    selected[equal_indices] = 1
                else:
                    chosen_indices = np.random.choice(equal_indices, remaining_spots, replace=False)
                    selected[chosen_indices] = 1

        # Ensure only positive values can be selected
        selected = selected & (tau_hat > 0)

        return selected

    pi_Y_hat = select_top_lambda(tau_Y_hat, lambda_val)
    pi_S_hat = select_top_lambda(tau_S_hat, lambda_val)

    return pi_Y_hat, pi_S_hat

# Compute R_n
def compute_R_n(pi_Y_hat, pi_S_hat, A, e_hat, Y, mu_A_hat, tau_Y_hat):
    e_hat = np.clip(e_hat, 0.1, 0.9)

    ipw_weights = A / e_hat - (1 - A) / (1 - e_hat)
    q99 = np.percentile(np.abs(ipw_weights), 99)
    ipw_weights = np.sign(ipw_weights) * np.minimum(np.abs(ipw_weights), q99)

    residuals = Y - mu_A_hat
    decision_diff = pi_Y_hat - pi_S_hat

    part1 = decision_diff * ipw_weights * residuals
    part2 = tau_Y_hat * decision_diff

    individual_values = part1 + part2
    R_n = np.mean(individual_values)
    print(np.mean(part1), np.mean(part2))

    return R_n, individual_values

