# Estimate propensity score e(X) = P(A=1|X)
def estimate_propensity_score(X, A):
    model = LogisticRegression(max_iter=1000)
    model.fit(X, A)
    return model


# Estimate conditional expectation μ_a(X) = E[Y|A=a,X]
