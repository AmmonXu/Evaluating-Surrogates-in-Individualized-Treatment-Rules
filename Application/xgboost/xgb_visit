    # Estimate μ_1(X) and μ_0(X) respectively
    X_treated = X[A == 1]
    Y_treated = Y[A == 1]
    X_control = X[A == 0]
    Y_control = Y[A == 0]

    model_1 = xgb.XGBRegressor(
        n_estimators=90,       
        learning_rate=0.1,      
        max_depth=5,         
        subsample=0.8,          
        colsample_bytree=0.8,   
        random_state=42,
        n_jobs=-1
    )
    model_0 = xgb.XGBRegressor(
        n_estimators=90,       
        learning_rate=0.1,      
        max_depth=5,         
        subsample=0.8,          
        colsample_bytree=0.8,   
        random_state=42,
        n_jobs=-1
    )
    print(X_treated.shape, Y_treated.shape)
    if len(X_treated) > 0:
        model_1.fit(X_treated, Y_treated)
    if len(X_control) > 0:
        model_0.fit(X_control, Y_control)

    return model_1, model_0


# Estimate CATE tau_Y(X)
def estimate_tau_Y(X_train, A_train, Y_train):
    # Estimate CATE using S-learner method
    X_with_A = np.column_stack((X_train, A_train))
    model = xgb.XGBRegressor(
        n_estimators=90,       
        learning_rate=0.1,      
        max_depth=5,         
        subsample=0.8,          
        colsample_bytree=0.8,   
        random_state=42,
        n_jobs=-1
    )
    model.fit(X_with_A, Y_train)

    # Predict results for X under A=1 and A=0
    X_with_A_1 = np.column_stack((X_train, np.ones(X_train.shape[0])))
    X_with_A_0 = np.column_stack((X_train, np.zeros(X_train.shape[0])))

    Y_hat_1 = model.predict(X_with_A_1)
    Y_hat_0 = model.predict(X_with_A_0)

    return model, Y_hat_1 - Y_hat_0


# Estimate CATE tau_S(X)
