def asymptotic_confidence_interval(individual_values, alpha=0.05):
    """Estimate the confidence interval of R_n using asymptotic normality"""
    n_samples = len(individual_values)

    R_n = np.mean(individual_values)
    influence_variance = np.var(individual_values, ddof=1)
    asymptotic_se = np.sqrt(influence_variance / n_samples)

    z_alpha = stats.norm.ppf(1 - alpha / 2)
    ci_lower = R_n - z_alpha * asymptotic_se
    ci_upper = R_n + z_alpha * asymptotic_se

    return {
        'R_n': R_n,
        'asymptotic_se': asymptotic_se,
        'confidence_interval': (ci_lower, ci_upper)
    }


def process_real_data(X, A, S, Y, sample_fraction=0.01, alpha=0.05, load_saved_models=False):
    """Process real data and compute Rn and confidence intervals"""

    # If loading saved models
    if load_saved_models and os.path.exists(MODEL_DIR):
        print("Loading saved models...")
        try:
            propensity_model, mu_1_model, mu_0_model, tau_Y_model, tau_S_model, test_data = load_models()
            X_test = test_data['X_test']
            A_test = test_data['A_test']
            Y_test = test_data['Y_test']
            S_test = test_data['S_test']
            print(f"Test set size: {len(X_test)}")
        except:
            print("Failed to load models, retraining...")
            load_saved_models = False

    # If not loading models or loading fails, retrain
    if not load_saved_models:
        n_total = len(X)
        n_sample = int(n_total * sample_fraction)

        print(f"Randomly sample {n_sample} records from {n_total} records ({sample_fraction * 100}%)")

        indices = np.random.choice(n_total, size=n_sample, replace=False)
        X_sampled = X[indices]
        A_sampled = A[indices]
        S_sampled = S[indices]
        Y_sampled = Y[indices]

        X_train, X_test, A_train, A_test, Y_train, Y_test, S_train, S_test = train_test_split(
            X_sampled, A_sampled, Y_sampled, S_sampled, test_size=0.3, random_state=42)

        print(f"Train set size: {len(X_train)}, Test set size: {len(X_test)}")

        # Fit models
        propensity_model = estimate_propensity_score(X_train, A_train)
        mu_1_model, mu_0_model = estimate_conditional_expectation(X_train, A_train, Y_train)
        tau_Y_model, _ = estimate_tau_Y(X_train, A_train, Y_train)
        tau_S_model, _ = estimate_tau_S(X_train, A_train, S_train)

        # Save models
        save_models(propensity_model, mu_1_model, mu_0_model, tau_Y_model, tau_S_model,
                    X_test, A_test, Y_test, S_test)

    # Predict on test set
    e_hat_test = propensity_model.predict_proba(X_test)[:, 1]
    e_hat_test = np.clip(e_hat_test, 0.1, 0.9)

    mu_1_hat_test = mu_1_model.predict(X_test)
    mu_0_hat_test = mu_0_model.predict(X_test)
    mu_A_hat_test = A_test * mu_1_hat_test + (1 - A_test) * mu_0_hat_test

    X_test_with_A_1 = np.column_stack((X_test, np.ones(len(X_test))))
    X_test_with_A_0 = np.column_stack((X_test, np.zeros(len(X_test))))

    tau_Y_hat_test = tau_Y_model.predict(X_test_with_A_1) - tau_Y_model.predict(X_test_with_A_0)
    tau_S_hat_test = tau_S_model.predict(X_test_with_A_1) - tau_S_model.predict(X_test_with_A_0)

    pi_Y_hat_test, pi_S_hat_test = estimate_decision_rules(tau_Y_hat_test, tau_S_hat_test, lambda_val)

    R_n, individual_values = compute_R_n(
        pi_Y_hat_test, pi_S_hat_test, A_test, e_hat_test, Y_test, mu_A_hat_test, tau_Y_hat_test
    )

    V_n, individual_values_ = compute_V_n(
        pi_S_hat_test, A_test, e_hat_test, Y_test, mu_A_hat_test, tau_Y_hat_test, lambda_val=lambda_val
    )

    G_n, individual_values__ = compute_G_n(
        pi_S_hat_test, A_test, e_hat_test, Y_test, mu_0_hat_test, mu_A_hat_test, tau_Y_hat_test, lambda_param=lambda_val
    )

    print(np.mean(pi_Y_hat_test), np.mean(pi_S_hat_test))

    results = asymptotic_confidence_interval(individual_values, alpha=alpha)
    results_v = asymptotic_confidence_interval(individual_values_, alpha=alpha)
    results_g = asymptotic_confidence_interval(individual_values__, alpha=alpha)

    print(f"R_n: {results['R_n']:.6f}")
    print(f"Standard deviation: {results['asymptotic_se']:.6f}")
    print(f"95% Confidence Interval: [{results['confidence_interval'][0]:.6f}, {results['confidence_interval'][1]:.6f}]")

    print(f"V_n: {results_v['R_n']:.6f}")
    print(f"Standard deviation: {results_v['asymptotic_se']:.6f}")
    print(f"95% Confidence Interval: [{results_v['confidence_interval'][0]:.6f}, {results_v['confidence_interval'][1]:.6f}]")

    print(f"G_n: {results_g['R_n']:.6f}")
    print(f"Standard deviation: {results_g['asymptotic_se']:.6f}")
    print(f"95% Confidence Interval: [{results_g['confidence_interval'][0]:.6f}, {results_g['confidence_interval'][1]:.6f}]")

    return results


