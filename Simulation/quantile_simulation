def evaluate_coverage(true_R, bootstrap_results, alpha=0.05):
    """
    Evaluate coverage of confidence intervals

    Parameters:
    - true_R: True R value
    - bootstrap_results: Dictionary of results from bootstrap method
    - alpha: Significance level

    Returns:
    - coverage_metrics: Dictionary containing coverage metrics
    """
    # Check coverage of normal approximation method
    ci_normal_lower, ci_normal_upper = bootstrap_results['ci_normal']
    normal_covers = (ci_normal_lower <= true_R <= ci_normal_upper)

    # Check coverage of percentile method
    ci_percentile_lower, ci_percentile_upper = bootstrap_results['ci_percentile']
    percentile_covers = (ci_percentile_lower <= true_R <= ci_percentile_upper)

    # Compute interval length
    normal_length = ci_normal_upper - ci_normal_lower
    percentile_length = ci_percentile_upper - ci_percentile_lower

    return {
        'normal_covers': normal_covers,
        'percentile_covers': percentile_covers,
        'normal_length': normal_length,
        'percentile_length': percentile_length,
        'expected_coverage': 1 - alpha
    }

