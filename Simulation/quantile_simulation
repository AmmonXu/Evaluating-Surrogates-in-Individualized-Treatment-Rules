# Compute true V (using Monte Carlo integration)
def compute_V(n_samples=100000, lambda_val=lambda_val_f(), seed=None):
    """
    Compute true expected V using Monte Carlo integration

    V(\lambda) = E[ tau_Y(X) * (pi_{S, \lambda}(X) - \lambda) ]

    Approximate this expectation by generating a large number of samples from the true distribution and computing the average.
    """
    if seed is not None:
        np.random.seed(seed)

    # Generate a large number of samples for Monte Carlo integration
    # Generate covariates X
    X = generate_X(n_samples)
    lambda_val = lambda_val_f()

    # Compute true propensity score e(X)
    propensity_score = propensity_score_f(X)
    propensity_score = np.clip(propensity_score, 0.3, 0.7)

    # Generate treatment variable A
    A = np.random.binomial(1, propensity_score, size=n_samples)

    # Compute true tau_Y(X) and tau_S(X)
    mu_1, mu_0, smu_1, smu_0, Y_1, Y_0, S_1, S_0 = generate_SY(n_samples, X)

    tau_Y_true = mu_1 - mu_0
    tau_S_true = smu_1 - smu_0

    s_lambda = np.quantile(tau_S_true, 1 - lambda_val)

    # Generate true decision rules pi_{S, \lambda}(X)
    _, pi_S_true = estimate_decision_rules(tau_Y_true, tau_S_true, lambda_val=lambda_val_f())

    # Compute V = E[tau_Y(X) * (pi_{S, \lambda}(X) - \lambda)]
    # Only need the second part, because the expectation of the first part is 0 (similar to taking only part2 in the R function)
    individual_values = tau_Y_true * (pi_S_true - lambda_val)
    V = np.mean(individual_values)

    return V

# Compute V_n (estimated value)
def compute_V_n(pi_S_hat, A, e_hat, Y, mu_A_hat, tau_Y_hat, lambda_val):
    """
    Compute the estimated value of surrogate efficiency V_n

    Influence function:
    psi_lambda(Y, A, X; eta_lambda) = [pi_{S, lambda}(X) - lambda] *
    {A/e(X) - (1-A)/(1-e(X))} * [Y - mu_A(X)] + tau_Y(X) * [pi_{S, lambda}(X) - lambda]
    """
    # Use looser truncation bounds
    e_hat = np.clip(e_hat, 0.3, 0.7)

    # Compute IPW weights (A/e_hat(X) - (1-A)/(1-e_hat(X)))
    ipw_weights = A / e_hat - (1 - A) / (1 - e_hat)

    # Handle extreme weight values
    q99 = np.percentile(np.abs(ipw_weights), 90)
    ipw_weights = np.sign(ipw_weights) * np.minimum(np.abs(ipw_weights), q99)

    # Compute residuals (Y - mu_A_hat(X))
    residuals = Y - mu_A_hat

    # Compute decision difference (pi_S_hat(X) - lambda)
    decision_diff = pi_S_hat - lambda_val

    # Compute part 1: [pi_S_hat(X) - lambda] * (A/e_hat(X) - (1-A)/(1-e_hat(X))) * [Y - mu_A_hat(X)]
    part1 = decision_diff * ipw_weights * residuals

    # Compute part 2: tau_Y_hat(X) * [pi_S_hat(X) - lambda]
    part2 = tau_Y_hat * decision_diff

    # Compute the value for each sample and take the average
    individual_values = part1 + part2
    V_n = np.mean(individual_values)

    return V_n, individual_values

