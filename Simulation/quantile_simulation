# Compute G_n (estimated value)
def compute_G_n(pi_S_hat, A, e_hat, Y, mu_0_hat, mu_A_hat, tau_Y_hat):
    """
    Compute the estimated value of surrogate efficiency V_n

    Influence function:
    psi_lambda(Y, A, X; eta_lambda) = [pi_{S, lambda}(X) - lambda] *
    {A/e(X) - (1-A)/(1-e(X))} * [Y - mu_A(X)] + tau_Y(X) * [pi_{S, lambda}(X) - lambda]
    """
    # Use looser truncation bounds
    e_hat = np.clip(e_hat, 0.3, 0.7)

    # Compute IPW weights (A/e_hat(X) - (1-A)/(1-e_hat(X)))
    ipw_weights_2 = A / e_hat - (1 - A) / (1 - e_hat)

    # Handle extreme weight values
    # Use winsorization instead of simple truncation
    q99 = np.percentile(np.abs(ipw_weights_2), 90)
    ipw_weights_2 = np.sign(ipw_weights_2) * np.minimum(np.abs(ipw_weights_2), q99)

    # Compute residuals (Y - mu_A_hat(X))
    residuals_1 = Y - mu_0_hat
    residuals_2 = Y - mu_A_hat

    # Compute part 1
    part1 = pi_S_hat * ipw_weights_2 * residuals_2

    # Compute part 2
    part2 = tau_Y_hat * pi_S_hat

    # Compute the value for each sample and take the average
    individual_values = part1 + part2
    G_n = np.mean(individual_values)

    return G_n, individual_values

def bootstrap_confidence_interval(X_test, A_test, Y_test, S_test,
                                  propensity_model, mu_1_model, mu_0_model,
                                  tau_Y_model_1, tau_Y_model_0, tau_S_model_1,
                                  tau_S_model_0, lambda_val, n_bootstrap=10000, alpha=0.05):
    """
    Use bootstrap method to estimate the sampling distribution of R_n and construct confidence intervals

    Parameters:
    - X_test, A_test, Y_test, S_test: Test set data
    - propensity_model, mu_1_model, mu_0_model, tau_Y_model, tau_S_model: Estimated models
    - n_bootstrap: Number of bootstrap repetitions
    - alpha: Significance level (e.g., 0.05 for 95% CI)

    Returns:
    - R_n: Point estimate
    - bootstrap_means: Mean of R_n from bootstrap samples
    - bootstrap_vars: Variance of R_n from bootstrap samples
    - ci_lower, ci_upper: Confidence interval of R
    """
    bootstrap_Rns = []
    bootstrap_Vns = []
    bootstrap_Gns = []

    n_samples = len(X_test)
    lambda_val=lambda_val_f()

    # Pre-compute all predictions on the test set to avoid redundant calculations
    e_hat_test = propensity_model.predict_proba(X_test)[:, 1]
    e_hat_test = np.clip(e_hat_test, 0.3, 0.7)  # Avoid extreme values

    if hasattr(mu_1_model, 'predict'):
        mu_1_hat_test = mu_1_model.predict(X_test)
    else:
        mu_1_hat_test = np.zeros(n_samples)

    if hasattr(mu_0_model, 'predict'):
        mu_0_hat_test = mu_0_model.predict(X_test)
    else:
        mu_0_hat_test = np.zeros(n_samples)

    mu_A_hat_test = A_test * mu_1_hat_test + (1 - A_test) * mu_0_hat_test

    X_test_with_A_1 = np.column_stack((X_test, np.ones(n_samples)))
    X_test_with_A_0 = np.column_stack((X_test, np.zeros(n_samples)))

    tau_Y_hat_test = tau_Y_model_1.predict(X_test) - tau_Y_model_0.predict(X_test)
    tau_S_hat_test = tau_S_model_1.predict(X_test) - tau_S_model_0.predict(X_test)

    pi_Y_hat_test, pi_S_hat_test = estimate_decision_rules(tau_Y_hat_test, tau_S_hat_test, lambda_val=lambda_val_f())
    # Compute original R_n
    R_n, individual_values = compute_R_n(
        pi_Y_hat_test,
        pi_S_hat_test,
        A_test,
        e_hat_test,
        Y_test,
        mu_A_hat_test,
        tau_Y_hat_test
    )

    # Perform bootstrap resampling
    rng = np.random.RandomState(42)  # Set random seed to ensure reproducibility

    for _ in range(n_bootstrap):
        # Sample indices with replacement
        bootstrap_indices = rng.choice(n_samples, size=n_samples, replace=True)
        bootstrap_values = individual_values[bootstrap_indices]
        bootstrap_Rn = np.mean(bootstrap_values)
        bootstrap_Rns.append(bootstrap_Rn)

    # Compute statistics of the bootstrap distribution
    bootstrap_Rns = np.array(bootstrap_Rns)
    bootstrap_mean = np.mean(bootstrap_Rns)
    bootstrap_var = np.var(bootstrap_Rns)
    bootstrap_std = np.sqrt(bootstrap_var)

    # Compute confidence interval based on normal approximation
    # Method 1: Use standard normal quantiles and bootstrap standard deviation
    z_alpha = stats.norm.ppf(1 - alpha / 2)
    ci_normal_lower = R_n - z_alpha * bootstrap_std
    ci_normal_upper = R_n + z_alpha * bootstrap_std

    # Method 2: Use quantiles of the bootstrap distribution (non-parametric method)
    ci_percentile_lower = np.percentile(bootstrap_Rns, 100 * alpha / 2)
    ci_percentile_upper = np.percentile(bootstrap_Rns, 100 * (1 - alpha / 2))

    # Return results from both confidence interval methods
    bootstrap_results_R = {
        'R_n': R_n,
        'bootstrap_mean': bootstrap_mean,
        'bootstrap_var': bootstrap_var,
        'bootstrap_std': bootstrap_std,
        'ci_normal': (ci_normal_lower, ci_normal_upper),
        'ci_percentile': (ci_percentile_lower, ci_percentile_upper),
        'bootstrap_distribution': bootstrap_Rns
    }

    V_n, individual_values = compute_V_n(
        pi_S_hat_test,
        A_test,
        e_hat_test,
        Y_test,
        mu_A_hat_test,
        tau_Y_hat_test,
        lambda_val=lambda_val_f()
    )

    # Perform bootstrap resampling
    rng = np.random.RandomState(42)

    for _ in range(n_bootstrap):
        bootstrap_indices = rng.choice(n_samples, size=n_samples, replace=True)
        bootstrap_values = individual_values[bootstrap_indices]
        bootstrap_Vn = np.mean(bootstrap_values)
        bootstrap_Vns.append(bootstrap_Vn)

    # Compute statistics of the bootstrap distribution
    bootstrap_Vns = np.array(bootstrap_Vns)
    bootstrap_mean = np.mean(bootstrap_Vns)
    bootstrap_var = np.var(bootstrap_Vns)
    bootstrap_std = np.sqrt(bootstrap_var)

    # Compute confidence interval
    z_alpha = stats.norm.ppf(1 - alpha / 2)
    ci_normal_lower = V_n - z_alpha * bootstrap_std
    ci_normal_upper = V_n + z_alpha * bootstrap_std

    ci_percentile_lower = np.percentile(bootstrap_Vns, 100 * alpha / 2)
    ci_percentile_upper = np.percentile(bootstrap_Vns, 100 * (1 - alpha / 2))

    bootstrap_results_V = {
        'V_n': V_n,
        'bootstrap_mean': bootstrap_mean,
        'bootstrap_var': bootstrap_var,
        'bootstrap_std': bootstrap_std,
        'ci_normal': (ci_normal_lower, ci_normal_upper),
        'ci_percentile': (ci_percentile_lower, ci_percentile_upper),
        'bootstrap_distribution': bootstrap_Vns
    }

    G_n, individual_values = compute_G_n(
        pi_S_hat_test,
        A_test,
        e_hat_test,
        Y_test,
        mu_0_hat_test,
        mu_A_hat_test,
        tau_Y_hat_test
    )

    # Perform bootstrap resampling
    rng = np.random.RandomState(42)

    for _ in range(n_bootstrap):
        bootstrap_indices = rng.choice(n_samples, size=n_samples, replace=True)
        bootstrap_values = individual_values[bootstrap_indices]
        bootstrap_Gn = np.mean(bootstrap_values)
        bootstrap_Gns.append(bootstrap_Gn)

    # Compute statistics of the bootstrap distribution
    bootstrap_Gns = np.array(bootstrap_Gns)
    bootstrap_mean = np.mean(bootstrap_Gns)
    bootstrap_var = np.var(bootstrap_Gns)
    bootstrap_std = np.sqrt(bootstrap_var)

    # Compute confidence interval
    z_alpha = stats.norm.ppf(1 - alpha / 2)
    ci_normal_lower = G_n - z_alpha * bootstrap_std
    ci_normal_upper = G_n + z_alpha * bootstrap_std

    ci_percentile_lower = np.percentile(bootstrap_Gns, 100 * alpha / 2)
    ci_percentile_upper = np.percentile(bootstrap_Gns, 100 * (1 - alpha / 2))

    bootstrap_results_G = {
        'G_n': G_n,
        'bootstrap_mean': bootstrap_mean,
        'bootstrap_var': bootstrap_var,
        'bootstrap_std': bootstrap_std,
        'ci_normal': (ci_normal_lower, ci_normal_upper),
        'ci_percentile': (ci_percentile_lower, ci_percentile_upper),
        'bootstrap_distribution': bootstrap_Gns
    }

    return bootstrap_results_R, bootstrap_results_V, bootstrap_results_G

