def single_experiment_with_bootstrap(n_samples=2000, seed=None, true_R=None, true_V=None, true_G=None,
                                     n_bootstrap=1000, alpha=0.05):
    if seed is not None:
        np.random.seed(seed)

    # Generate data
    data = generate_data(n_samples=n_samples, seed=seed)
    X, A, Y, S = data['X'], data['A'], data['Y'], data['S']

    # Split data into three parts
    X_train1, X_rest, A_train1, A_rest, Y_train1, Y_rest, S_train1, S_rest = train_test_split(
        X, A, Y, S, test_size=2 / 3, random_state=seed)

    X_train2, X_test, A_train2, A_test, Y_train2, Y_test, S_train2, S_test = train_test_split(
        X_rest, A_rest, Y_rest, S_rest, test_size=1 / 2, random_state=seed)

    # Use the first part of data to estimate models
    # 1. Estimate propensity score e(X)
    propensity_model = estimate_propensity_score(X_train1, A_train1)

    # 2. Estimate conditional expectation μ_a(X)
    mu_1_model, mu_0_model = estimate_conditional_expectation(X_train1, A_train1, Y_train1)

    # 3. Estimate CATE tau_Y(X)
    tau_Y_model_1, tau_Y_model_0, _ = estimate_tau_Y(X_train1, A_train1, Y_train1)

    # 4. Estimate CATE tau_S(X)
    tau_S_model_1, tau_S_model_0, _ = estimate_tau_S(X_train1, A_train1, S_train1)

    # Use bootstrap method to estimate confidence intervals
    bootstrap_results_R, bootstrap_results_V, bootstrap_results_G = bootstrap_confidence_interval(
        X_test, A_test, Y_test, S_test,
        propensity_model, mu_1_model, mu_0_model,
        tau_Y_model_1, tau_Y_model_0, tau_S_model_1, tau_S_model_0, lambda_val=lambda_val_f(),
        n_bootstrap=n_bootstrap, alpha=alpha
    )

    # Evaluate coverage (if true_R is provided)
    coverage_metrics = None
    if true_R is not None:
        coverage_metrics = evaluate_coverage(true_R, bootstrap_results_R, alpha=alpha)

    # Predict e_hat on the test set
    e_hat_test = propensity_model.predict_proba(X_test)[:, 1]

    # Compute sqrt(n) * (R_n - R)
    n_test = len(X_test)
    R_n = bootstrap_results_R['R_n']
    statistic = np.sqrt(n_test) * (R_n - true_R) if true_R is not None else None

    exp_result_R = {
        'statistic': statistic,
        'R_n': R_n,
        'n_test': n_test,
        'bootstrap_results': bootstrap_results_R,
        'coverage_metrics': coverage_metrics
    }

    coverage_metrics = None
    if true_V is not None:
        coverage_metrics = evaluate_coverage(true_V, bootstrap_results_V, alpha=alpha)

    # Compute sqrt(n) * (V_n - V)
    V_n = bootstrap_results_V['V_n']
    statistic = np.sqrt(n_test) * (V_n - true_V) if true_V is not None else None

    exp_result_V = {
        'statistic': statistic,
        'V_n': V_n,
        'n_test': n_test,
        'bootstrap_results': bootstrap_results_V,
        'coverage_metrics': coverage_metrics
    }

    coverage_metrics = None
    if true_G is not None:
        coverage_metrics = evaluate_coverage(true_G, bootstrap_results_G, alpha=alpha)

    # Compute sqrt(n) * (G_n - G)
    G_n = bootstrap_results_G['G_n']
    statistic = np.sqrt(n_test) * (G_n - true_G) if true_G is not None else None

    exp_result_G = {
        'statistic': statistic,
        'G_n': G_n,
        'n_test': n_test,
        'bootstrap_results': bootstrap_results_G,
        'coverage_metrics': coverage_metrics
    }
    return exp_result_R, exp_result_V, exp_result_G


# Run multiple experiments for evaluation
def run_coverage_experiments(n_experiments=100, n_samples=2000,
                             n_bootstrap=1000, alpha=0.05):
    """
    Run multiple experiments and evaluate the coverage of confidence intervals
    """
    # First compute the true R value (only need to compute once)
    print("Compute true R value...")
    true_R = compute_R(n_samples=100000, seed=42)
    true_V = compute_V(n_samples=100000, seed=42)
    true_G = compute_G(n_samples=100000, seed=42)
