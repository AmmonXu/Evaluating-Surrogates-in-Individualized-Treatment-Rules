    """
    Compute true expected R using Monte Carlo integration

    R = E{ [pi_{Y, lambda}(X) - pi_{S, lambda}(X)](A/e(X) -
    (1-A)/(1-e(X)))[Y - mu_A(X)] + tau_Y(X) * [pi_{Y, lambda}(X) - pi_{S, lambda}(X)] }

    Approximate this expectation by generating a large number of samples from the true distribution and computing the average.
    """
    if seed is not None:
        np.random.seed(seed)

    lambda_val=lambda_val_f()
    # Generate a large number of samples for Monte Carlo integration
    # Generate covariates X
    X = generate_X(n_samples)

    # Compute true propensity score e(X)
    propensity_score = propensity_score_f(X)
    propensity_score = np.clip(propensity_score, 0.3, 0.7)

    # Generate treatment variable A
    A = np.random.binomial(1, propensity_score, size=n_samples)

    # Compute true tau_Y(X) and tau_S(X)
    # tau_Y_true = 0.1 * (X[:, 0] ** 2 + X[:, 1] ** 2) + 1.8 * X[:, 0] + 1.5 * X[:, 1]
    # tau_S_true = 0.1 * (X[:, 0] ** 2 + X[:, 1] ** 2) + 0.6 * X[:, 0] - 0.3 * X[:, 1]
    mu_1_true, mu_0_true, smu_1, smu_0, Y_1, Y_0, S_1, S_0 = generate_SY(n_samples, X)

    tau_Y_true = mu_1_true - mu_0_true
    tau_S_true = smu_1 - smu_0

    q_lambda = np.quantile(tau_Y_true, 1 - lambda_val)
    s_lambda = np.quantile(tau_S_true, 1 - lambda_val)

    # Generate true decision rules
    pi_Y_true, pi_S_true = estimate_decision_rules(tau_Y_true, tau_S_true, lambda_val=lambda_val_f())
    # pi_Y_true = ((tau_Y_true > q_lambda) & (tau_Y_true > 0)).astype(int)
    # pi_S_true = ((tau_S_true > s_lambda) & (tau_S_true > 0)).astype(int)

    # Generate observed outcomes Y = A*Y(1) + (1-A)*Y(0)
    Y = A * Y_1 + (1 - A) * Y_0

    # Compute μ_A(X) = A*μ_1(X) + (1-A)*μ_0(X)
    mu_A_true = A * mu_1_true + (1 - A) * mu_0_true

    # Use looser truncation bounds
    e_true = np.clip(propensity_score, 0.3, 0.7)

    # Compute IPW weights (A/e(X) - (1-A)/(1-e(X)))
    ipw_weights = A / e_true - (1 - A) / (1 - e_true)

    # Handle extreme weight values, using the same method as computing R_n
    q99 = np.percentile(np.abs(ipw_weights), 90)
    ipw_weights = np.sign(ipw_weights) * np.minimum(np.abs(ipw_weights), q99)

    # Compute residuals (Y - mu_A(X))
    residuals = Y - mu_A_true

    # Compute decision difference (pi_Y(X) - pi_S(X))
    decision_diff = pi_Y_true - pi_S_true

    # Compute part 1: [pi_Y(X) - pi_S(X)] * (A/e(X) - (1-A)/(1-e(X))) * [Y - mu_A(X)]
    part1 = (pi_Y_true - pi_S_true) * ipw_weights * residuals

    # Compute part 2: tau_Y(X) * [pi_Y(X) - pi_S(X)]
    part2 = tau_Y_true * decision_diff
    # print(tau_Y_true.mean(), decision_diff.mean())

