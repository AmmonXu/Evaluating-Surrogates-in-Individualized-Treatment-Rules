np.random.seed(42)

def lambda_val_f():
    return 0.1

def compute_tau_Y(X):
    # return -1 + 1.5 * X[:, 0] + 0.6 * X[:, 1]
    return 0.3 * (X[:, 0] ** 2 + X[:, 1] ** 2) + 1.8 * X[:, 0] + 0.6 * X[:, 1]

def compute_tau_S(X):
    # return -0.5 + 1.2 * X[:, 0] + 0.3 * X[:, 1]
    return 0.3 * (X[:, 0] ** 2 + X[:, 1] ** 2) + 1.6 * X[:, 0] + 0.3 * X[:, 1]

def compute_base_mean(X):
    return 1.0 + 0.3 * X[:, 0] + 0.2 * X[:, 1]

def compute_base_mean_s(X):
    return 0.5 + 0.2 * X[:, 0] + 0.1 * X[:, 1]

def generate_epsilon(n_samples):
    return np.random.normal(0, 1, size=n_samples)

def propensity_score_f(X):
    # print(1 / (1 + np.exp(-(0.3 * X[:, 0] + 0.2 * X[:, 1]))))
    return 1 / (1 + np.exp(-(0.1 * X[:, 0] + 0.1 * X[:, 1])))

def generate_X(n_samples):
    # return np.random.binomial(1, 0.3, size=(n_samples, 2))
    return np.random.normal(0, 1, size=(n_samples, 2))
    # return np.random.uniform(-2, 2, (n_samples, 2))

def generate_SY(n_samples, X):
    # === Potential outcomes for Y ===
    # Y(1): Potential outcome for the treatment group
    logit_y1 = 0.1 * X[:, 0] + 0.1 * X[:, 1] + 0.2
    prob_y1 = 1 / (1 + np.exp(-logit_y1))
    Y1 = np.random.binomial(1, prob_y1, size=n_samples)

    # Y(0): Potential outcome for the control group
    logit_y0 = 0.2 * X[:, 0] ** 2 + 0.2 * X[:, 1] + 0.1
    prob_y0 = 1 / (1 + np.exp(-logit_y0))
    Y0 = np.random.binomial(1, prob_y0, size=n_samples)

    # === Potential outcomes for S ===
    # S(1): Surrogate outcome for the treatment group
    logit_s1 = 0.3 * X[:, 0] + 0.2 * X[:, 1] + 0.2
    prob_s1 = 1 / (1 + np.exp(-logit_s1))
    S1 = np.random.binomial(1, prob_s1, size=n_samples)

    # S(0): Surrogate outcome for the control group
    logit_s0 = 0.2 * X[:, 0] ** 2 + 0.1 * X[:, 1] + 0.1
    prob_s0 = 1 / (1 + np.exp(-logit_s0))
    S0 = np.random.binomial(1, prob_s0, size=n_samples)
    return prob_y1, prob_y0, prob_s1, prob_s0, Y1, Y0, S1, S0

# Function to generate data
def generate_data(n_samples=10000, seed=None):
    if seed is not None:
        np.random.seed(seed)

    # Generate covariates X using normal distribution (dimension 2)
    X = generate_X(n_samples)

    # Set propensity score e(X) = P(A=1|X)
    # Use sigmoid function to ensure overlap condition is met
    propensity_score = propensity_score_f(X)
    propensity_score = np.clip(propensity_score, 0.3, 0.7)  # Avoid extreme values

    # Generate treatment variable A ~ Bernoulli(e(X))
    A = np.random.binomial(1, propensity_score, size=n_samples)

    # Simple linear form: tau(X) = X * beta
    # Use different coefficients for tau_Y and tau_S
    # tau_Y_true = (X[:, 0] ** 2 + X[:, 1] ** 2) + 1.8 * X[:, 0] + 1.5 * X[:, 1]
    # tau_S_true = (X[:, 0] ** 2 + X[:, 1] ** 2) + 0.6 * X[:, 0] - 0.3 * X[:, 1]

    # Generate potential outcomes, ensuring Y(1) - Y(0) = tau_Y_true
    mu_1_true, mu_0_true, smu_1, smu_0, Y_1, Y_0, S_1, S_0 = generate_SY(n_samples, X)

    tau_Y_true = mu_1_true - mu_0_true
    tau_S_true = smu_1 - smu_0

    # Generate observed outcomes Y = A*Y(1) + (1-A)*Y(0)
    Y = A * Y_1 + (1 - A) * Y_0
    # Generate observed surrogate outcomes S = A*S(1) + (1-A)*S(0)
    S = A * S_1 + (1 - A) * S_0

    # Generate true decision rules
    pi_Y_true, pi_S_true = estimate_decision_rules(tau_Y_true, tau_S_true, lambda_val = lambda_val_f())

    # True μ_A(X) = A*μ_1(X) + (1-A)*μ_0(X)
    mu_A_true = A * mu_1_true + (1 - A) * mu_0_true

    return {
        'X': X,
        'A': A,
        'Y': Y,
        'S': S,
        'Y_1': Y_1,  # Potential outcomes
        'Y_0': Y_0,  # Potential outcomes
        'S_1': S_1,  # Potential surrogate outcomes
        'S_0': S_0,  # Potential surrogate outcomes
        'propensity_score': propensity_score,  # e(X)
        'tau_Y_true': tau_Y_true,  # tau_Y(X)
        'tau_S_true': tau_S_true,  # tau_S(X)
        'pi_Y_true': pi_Y_true,  # π_Y(X)
        'pi_S_true': pi_S_true,  # π_S(X)
        'mu_1_true': mu_1_true,  # μ_1(X)
        'mu_0_true': mu_0_true,  # μ_0(X)
        'mu_A_true': mu_A_true,  # μ_A(X)
    }


