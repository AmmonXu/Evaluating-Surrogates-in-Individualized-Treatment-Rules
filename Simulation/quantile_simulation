    """
    Compute true expected V using Monte Carlo integration

    G(\lambda) = E[ tau_Y(X) * (pi_{S, \lambda}(X) - \lambda) ]

    Approximate this expectation by generating a large number of samples from the true distribution and computing the average.
    """
    if seed is not None:
        np.random.seed(seed)

    # Generate a large number of samples for Monte Carlo integration
    # Generate covariates X
    X = generate_X(n_samples)

    # Compute true propensity score e(X)
    propensity_score = propensity_score_f(X)
    propensity_score = np.clip(propensity_score, 0.3, 0.7)

    # Generate treatment variable A
    A = np.random.binomial(1, propensity_score, size=n_samples)

    # Compute true tau_Y(X) and tau_S(X)
    mu_1_true, mu_0_true, smu_1, smu_0, Y_1, Y_0, S_1, S_0 = generate_SY(n_samples, X)

    tau_Y_true = mu_1_true - mu_0_true
    tau_S_true = smu_1 - smu_0

    # Calculate quantile
    s_lambda = np.quantile(tau_S_true, 1 - lambda_val)

    # Generate true decision rules pi_{S, \lambda}(X)
    _, pi_S_true = estimate_decision_rules(tau_Y_true, tau_S_true, lambda_val=lambda_val_f())

    # Compute V = E[tau_Y(X) * (pi_{S, \lambda}(X) - \lambda)]
    # Only need the second part, because the expectation of the first part is 0 (similar to taking only part2 in the R function)
